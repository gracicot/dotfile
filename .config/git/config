[include]
	path = ~/.config/git/local

[submodule]
	recurse = true

[core]
	editor = nvim

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[push]
	recurseSubmodules = on-demand
	default = simple
	followTags = true

[pull]
	rebase = true

[fetch]
	prune = true
	pruneTags = true
	all = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[merge]
	conflictstyle = diff3

[init]
	defaultBranch = main

[commit]
	verbose = true

[rerere]
	enabled = true
	autoupdate = true

